<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"> <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnBrake"
        android:layout_width="120dp"
        android:layout_height="180dp"
        android:layout_marginStart="32dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="16dp"
        app:strokeColor="#333333"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_menu_help"
                app:tint="#888888" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="BRAKE"
                android:textColor="#888888"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/imgSteering"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@android:drawable/ic_menu_compass" 
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutGasGears"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/bottomSlider"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReverse"
                android:layout_width="100dp"
                android:layout_height="70dp"
                android:text="REVERSE"
                android:textColor="#888888"
                android:textSize="12sp"
                app:backgroundTint="#1A1A1A"
                app:cornerRadius="12dp"
                app:strokeColor="#333333"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFront"
                android:layout_width="100dp"
                android:layout_height="70dp"
                android:layout_marginTop="8dp"
                android:text="FRONT"
                android:textColor="#888888"
                android:textSize="12sp"
                app:backgroundTint="#1A1A1A"
                app:cornerRadius="12dp"
                app:strokeColor="#333333"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnGas"
            android:layout_width="120dp"
            android:layout_height="160dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="16dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#888888" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="GAS"
                    android:textColor="#888888"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutActionButtons"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutGasGears"
        app:layout_constraintEnd_toEndOf="@+id/layoutGasGears"
        app:layout_constraintStart_toStartOf="@+id/layoutGasGears">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnY"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="Y"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#FFC107" 
            app:rippleColor="#FFFFFF"
            app:cornerRadius="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnX"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="X"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#2196F3"
            app:rippleColor="#FFFFFF"
            app:cornerRadius="25dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnB"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="B"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#F44336"
            app:rippleColor="#FFFFFF"
            app:cornerRadius="25dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnA"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="A"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#4CAF50"
            app:rippleColor="#FFFFFF"
            app:cornerRadius="25dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/bottomSlider"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="16dp"
        android:background="#333333"
        app:layout_constraintBottom_toBottomOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="#A3A68B"
        app:layout_constraintBottom_toBottomOf="@+id/bottomSlider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.3"
        app:layout_constraintStart_toStartOf="@+id/bottomSlider"
        app:layout_constraintTop_toTopOf="@+id/bottomSlider"
        app:layout_constraintWidth_percent="0.5" />

</androidx.constraintlayout.widget.ConstraintLayout>