<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- LEFT = BRAKE big -->
    <FrameLayout
        android:id="@+id/lay_brake"
        android:layout_width="200dp"
        android:layout_height="280dp"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="16dp"
        android:background="@drawable/btn_normal"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ic_brake"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="48dp"
            android:src="@drawable/ic_hand"
            android:tint="#888888"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="BRAKE"
            android:textColor="#888888"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.1"/>

    </FrameLayout>

    <!-- CENTER = Wheel + status + tilt -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="232dp"
        android:paddingEnd="232dp">

        <TextView
            android:id="@+id/txt_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap wheel to connect"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:alpha="0.4"
            android:paddingBottom="12dp"/>

        <com.mrb.controller.pro.WheelView
            android:id="@+id/lay_steering"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <ProgressBar
            android:id="@+id/tilt_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginTop="16dp"
            android:max="200"
            android:progress="100"/>

        <TextView
            android:id="@+id/txt_tilt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0.0°"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:fontFamily="monospace"
            android:paddingTop="6dp"
            android:alpha="0.6"/>

    </LinearLayout>

    <!-- RIGHT = GAS big + REVERSE + FRONT -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical">

        <!-- REVERSE + FRONT column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="12dp">

            <FrameLayout
                android:id="@+id/lay_gear_up"
                android:layout_width="160dp"
                android:layout_height="120dp"
                android:background="@drawable/btn_normal"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="∧"
                    android:textSize="32sp"
                    android:textColor="#FF6D00"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:text="REVERSE"
                    android:textColor="#FF6D00"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.1"/>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/lay_gear_down"
                android:layout_width="160dp"
                android:layout_height="120dp"
                android:background="@drawable/btn_normal"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="∨"
                    android:textSize="32sp"
                    android:textColor="#00B4D8"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:text="FRONT"
                    android:textColor="#00B4D8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.1"/>
            </FrameLayout>

        </LinearLayout>

        <!-- GAS big -->
        <FrameLayout
            android:id="@+id/lay_gas"
            android:layout_width="200dp"
            android:layout_height="280dp"
            android:background="@drawable/btn_normal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ic_gas"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="48dp"
                android:src="@drawable/ic_speed"
                android:tint="#888888"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="20dp"
                android:text="GAS"
                android:textColor="#888888"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"/>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
